rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meal plans - user can only access their own
    match /meal_plans/{planId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    // User profiles
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Contact messages - anyone authenticated can create
    match /contact_messages/{msgId} {
      allow create: if request.auth != null;
    }
    // Token usage - authenticated users can create
    match /token_usage/{docId} {
      allow create: if request.auth != null;
    }
    // Finance tracker collections - open access (local-only personal app)
    match /finance_accounts/{docId} {
      allow read, write: if true;
    }
    match /finance_profiles/{userId} {
      allow read, write: if true;
    }
    match /finance_snapshots/{docId} {
      allow read, write: if true;
    }
    match /finance_analyses/{docId} {
      allow read, write: if true;
    }
    // Travel site inquiries - anyone can submit
    match /travel_inquiries/{docId} {
      allow create: if true;
    }
    // Reading list - open access (personal app)
    match /reading_links/{docId} {
      allow read, write: if true;
    }
    // What's Happening items
    match /whatshappening_items/{docId} {
      allow read, write: if true;
    }
    // What's Happening feedback (thumbs up/down)
    match /whatshappening_feedback/{docId} {
      allow read, write: if true;
    }
    // Travel places - open access (personal app)
    match /travel_places/{docId} {
      allow read, write: if true;
    }
    // Visited countries - open access (personal app)
    match /visited_countries/{docId} {
      allow read, write: if true;
    }
    // Bucket list - open access (personal app)
    match /bucket_list/{docId} {
      allow read, write: if true;
    }
    // Health tracker collections - open access (local-only personal app)
    match /health_entries/{docId} {
      allow read, write: if true;
    }
    match /health_profiles/{userId} {
      allow read, write: if true;
    }
    match /health_analyses/{docId} {
      allow read, write: if true;
    }
    // Todo tasks - open access (personal app)
    match /todo_tasks/{docId} {
      allow read, write: if true;
    }
    // Todo notes (monthly)
    match /todo_notes/{docId} {
      allow read, write: if true;
    }
    // Todo meta (archive config)
    match /todo_meta/{docId} {
      allow read, write: if true;
    }
    // Todo goals - open access (personal app)
    match /todo_goals/{docId} {
      allow read, write: if true;
    }
    // Musings - open access (personal app)
    match /musings_items/{docId} {
      allow read, write: if true;
    }
    // Fitness tracker - custom exercises (personal app)
    match /fitness_custom_exercises/{docId} {
      allow read, write: if true;
    }
  }
}
