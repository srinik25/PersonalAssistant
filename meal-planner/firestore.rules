rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Meal plans - user can only access their own
    match /meal_plans/{planId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    // User profiles
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Contact messages - anyone authenticated can create
    match /contact_messages/{msgId} {
      allow create: if request.auth != null;
    }
    // Token usage - authenticated users can create
    match /token_usage/{docId} {
      allow create: if request.auth != null;
    }
    // Finance tracker collections
    match /finance_accounts/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /finance_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /finance_snapshots/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /finance_analyses/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
